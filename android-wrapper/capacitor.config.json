{
  "appId": "com.energyai.optimizer",
  "appName": "EnergyAI",
  "webDir": "www",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2500,
      "backgroundColor": "#0D1117",
      "showSpinner": true,
      "spinnerColor": "#00FF88",
      "launchAutoHide": true
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#0D1117"
    }
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#0D1117",
    "webContentsDebuggingEnabled": true
  }
}